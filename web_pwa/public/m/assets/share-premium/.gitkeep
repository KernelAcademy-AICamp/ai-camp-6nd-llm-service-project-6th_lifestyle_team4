# 공유 카드 — Premium tier 카드지 이미지 폴더
# 가격: 실타래 999
#
# 비율: 9:16 (권장 해상도 1080 x 1920)
# 포맷: PNG / JPG / WebP (PNG 권장)
#
# 파일명 = m-app.js 의 SHARE_BACKGROUNDS 배열 id 와 매칭:
#   parchment.png   → 양피지
#   kraft.png       → 크라프트
#   midnight.png    → 미드나잇
#   rosegold.png    → 로즈골드
#
# 추가 흐름:
#   1) 이 폴더에 <id>.png 업로드
#   2) m-app.js 의 SHARE_BACKGROUNDS 배열에 항목 추가
#        { id: 'foo', name: '…', tier: 'premium', price: 999,
#          paint: (ctx, W, H) => paintImageBg(ctx, W, H, 'assets/share-premium/foo.png') }
