<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.DailyScript" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/paper</item>
        <item name="android:statusBarColor">@color/paper</item>
        <item name="android:navigationBarColor">@color/paper</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Launch splash: espresso background + centered Daily Script wordmark.
         Shown until the first app frame is drawn, then swaps to Theme.DailyScript. -->
    <style name="Theme.DailyScript.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.DailyScript</item>
    </style>
</resources>
