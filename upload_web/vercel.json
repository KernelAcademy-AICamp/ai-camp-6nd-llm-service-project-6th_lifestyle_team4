{
  "functions": {
    "api/extract.js": { "maxDuration": 300 },
    "api/translate.js": { "maxDuration": 120 },
    "api/save.js": { "maxDuration": 30 },
    "api/backfill-characters.js": { "maxDuration": 300 },
    "api/classify-keywords.js": { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/manifest-admin.webmanifest",
      "headers": [{ "key": "Content-Type", "value": "application/manifest+json" }]
    },
    {
      "source": "/sw.js",
      "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
    }
  ]
}
